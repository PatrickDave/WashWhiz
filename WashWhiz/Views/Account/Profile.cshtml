@model WashWhiz.Models.UserAccount

@{
    ViewData["Title"] = "My Profile";
}

<div class="container my-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-xl-7">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <strong>Success!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <strong>Error!</strong> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow border-0">
                <div class="card-header text-white text-center">
                    <h4 class="mb-0">My Profile</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-controller="Account" asp-action="Profile" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="text-center mb-4">
                            <img id="previewImage"
                                 src="~/profile_pics/@Model.ProfilePicture"
                                 class="rounded-circle shadow-sm"
                                 style="width:150px; height:150px; object-fit:cover; border: 3px solid #0d6efd;"
                                 asp-append-version="true" />

                            <div class="mt-3">
                                <input type="file" name="profilePic" class="form-control" accept="image/*"
                                       onchange="previewFile(event)" />
                            </div>
                        </div>

                        <h5 class="fw-bold text-primary mb-3">Account Information</h5>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Full Name</label>
                                <input asp-for="FullName" class="form-control" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Email</label>
                                <input asp-for="Email" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                        </div>

                        <hr />

                        <h5 class="fw-bold text-primary mb-3">Change Password</h5>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">Current Password</label>
                                <input type="password" name="currentPassword" class="form-control" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">New Password</label>
                                <input type="password" name="newPassword" class="form-control" />
                            </div>

                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">Confirm Password</label>
                                <input type="password" name="confirmPassword" class="form-control" />
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previewFile(event) {
            const preview = document.getElementById("previewImage");
            preview.src = URL.createObjectURL(event.target.files[0]);
        }
    </script>
}