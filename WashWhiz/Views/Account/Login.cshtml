@model WashWhiz.Models.UserAccount

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 border p-4 shadow rounded bg-white">
            <h3 class="text-center mb-4 fw-bold">Login to <span class="text-primary">WashWhiz</span></h3>

            @* Show server-side errors from ViewBag or TempData *@
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger" role="alert">
                    @TempData["ErrorMessage"]
                </div>
            }
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger" role="alert">
                    @ViewBag.Error
                </div>
            }

            <div class="role-toggle d-flex p-1 mb-4 bg-light rounded-pill">
                <button type="button" id="btnUser" class="btn w-50 rounded-pill active-role shadow-sm" onclick="setRole('User')">User</button>
                <button type="button" id="btnAdmin" class="btn w-50 rounded-pill" onclick="setRole('Admin')">Admin</button>
            </div>

            <form asp-action="Login" method="post">
                <input type="hidden" name="role" id="selectedRole" value="User" />

                <div class="mb-3">
                    <label id="identityLabel" class="form-label">Email Address</label>
                    <input type="text" id="identityInput" name="email" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" id="password" class="form-control" required />
                </div>
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="remember">
                    <label class="form-check-label" for="remember">Remember me</label>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2">Login</button>
            </form>

            <p class="mt-4 text-center small text-muted">
                New to WashWhiz? <a asp-action="Register">Create an account</a>
            </p>
        </div>
    </div>
</div>