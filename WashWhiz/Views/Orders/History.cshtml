@model IEnumerable<WashWhiz.Models.LaundryOrder>

@{
    bool isAdmin = ViewBag.IsAdmin == true;
    ViewData["Title"] = "Order History";

    string BadgeClass(string status) =>
        status == "Pending" ? "bg-warning" :
        status == "Washing" ? "bg-info" :
        status == "Ready" ? "bg-success" :
        status == "Completed" ? "bg-secondary" :
        "bg-primary";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">
            @(isAdmin ? "Completed Orders History" : "My Completed Orders")
        </h2>

        <a href="/Laundry/Dashboard" class="btn btn-outline-secondary">
            Back to Orders
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm text-center p-5">
            <h4 class="text-primary fw-bold">No completed orders yet</h4>
            <p class="text-muted mb-0">Completed laundry orders will appear here.</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>Customer Name</th>
                        <th>Weight</th>
                        <th>Service Type</th>
                        <th>Status</th>
                        <th>Date Received</th>
                        <th>Receipt</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="order-row">
                            <td class="fw-bold">@item.CustomerName</td>
                            <td>@item.Weight kg</td>
                            <td>@item.ServiceType</td>
                            <td>
                                <span class="badge @BadgeClass(item.Status)">@item.Status</span>
                            </td>
                            <td>@item.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td><a href="@Url.Action("GetReceipt", "Orders", new { id = item.LaundryOrderId })" class="btn btn-info btn-sm">View Receipt</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>